<style>
  .footer {
    position: relative;
    margin-top: 0;
    overflow: hidden;
  }

  .footer-body {
    background: #1D3035;
    padding: 48px 0 0;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .yt-banner {
    display: flex;
    align-items: center;
    gap: 16px;
    background: rgba(153, 19, 47, 0.12);
    border: 1px solid rgba(153, 19, 47, 0.3);
    border-radius: 4px;
    padding: 16px 24px;
    margin-bottom: 48px;
    text-decoration: none;
    transition: background 0.25s ease, border-color 0.25s ease;
  }

  .yt-banner:hover {
    background: rgba(153, 19, 47, 0.2);
    border-color: rgba(153, 19, 47, 0.6);
  }

  .yt-icon-wrap {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    background: #FF0000;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
  }

  .yt-banner-text {
    flex: 1;
    display: flex;
    align-items: baseline;
    gap: 12px;
    min-width: 0;
  }

  .yt-banner-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    white-space: nowrap;
  }

  .yt-banner-sub {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .yt-arrow {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .yt-banner:hover .yt-arrow {
    color: #fff;
    transform: translateX(3px);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-logo {
    height: 80px;
    width: auto;
    opacity: 0.85;
    transition: opacity 0.2s;
  }

  .footer-logo:hover {
    opacity: 1;
  }

  .footer-tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  .footer-email {
    display: inline-block;
    font-family: var(--font-condensed);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    transition: color 0.2s;
  }

  .footer-email:hover {
    color: var(--color-primary-hover);
  }

  .footer-socials {
    display: flex;
    gap: 6px;
    margin-top: 4px;
    flex-wrap: wrap;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: rgba(255,255,255,0.45);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .social-link:hover {
    color: #99132F;
    border-color: #99132F;
    background: rgba(153, 19, 47, 0.1);
  }

  .footer-col-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.45);
    margin: 0 0 16px 0;
  }

  .footer-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .footer-nav-list a {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    display: block;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .footer-nav-list a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 32px;
    margin-top: 0;
    padding-bottom: 32px;
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
    margin: 0;
  }

  .metavision-link {
    color: #e8c97a;
    text-decoration: underline;
    text-decoration-color: rgba(232, 201, 122, 0.4);
    text-underline-offset: 3px;
    transition: color 0.2s, text-decoration-color 0.2s;
    font-weight: 600;
  }

  .metavision-link:hover {
    color: #f5d98a;
    text-decoration-color: #f5d98a;
  }

  @media (max-width: 767px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .footer-brand-col,
    .footer-nav-col,
    .footer-legal-col {
      margin-bottom: 32px;
    }

    .yt-banner-text {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
    }
  }
</style>
