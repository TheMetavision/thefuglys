---
// src/components/FuglysTransmission.astro
//
// "Transmission Signal" — The Fuglys theme-tune control.
// Canonically: Harlan's scavenged radio rig broadcasting Wasteland Whispers.
//
// v3.1 — 2026-04-30 — adds dismiss + progress scrubber:
//   - Small circular X badge at the top-right corner of the widget. Click to
//     hide the player for the rest of this browser session. Returns next
//     visit (sessionStorage cleared on tab close).
//   - Progress bar below the main button shows playback position. Click
//     anywhere on the bar to seek to that position (works during playing,
//     and "back to beginning" by clicking the leftmost edge). ARIA slider
//     role + keyboard arrow-key support (5s steps).
//
// v3 INTERIM — 2026-04-29 — discoverability + cart-collision fix:
//   - Position bottom-right both desktop and mobile.
//   - Solid crimson fill, always-visible "TUNE IN?" label.
//   - Bounded attention pulse on initial load (2 cycles, ~3s, then stops).
//
// Per Arc spec arc-spec-fuglys-theme-tune-content-2026-04-29.md:
//   - All copy strings verbatim (Section D)
//   - Palette: canonical Fuglys (Section A.3)
//   - Voice anchor: scavenged radio rig coming alive (Section B.3)
//   - Reduced-motion variant (Section D.6) — non-negotiable
//   - ARIA labels exact (Section D.5)
//
// Data is fetched in Layout.astro (via getThemeAudio) and passed as props.

interface Props {
  audioUrl: string | null;
  trackTitle?: string | null;
  trackArtist?: string | null;
}

const { audioUrl, trackTitle = 'The Fuglys Main Theme', trackArtist = '' } = Astro.props;

const shouldRender = !!audioUrl;
---

{shouldRender && (
  <div
    id="fg-transmission"
    class="fg-transmission fg-state-idle"
    data-state="idle"
    data-namespace="fuglys"
    data-audio-src={audioUrl}
    data-track-title={trackTitle}
    data-track-artist={trackArtist}
    data-dismissed="false"
  >
    <button
      type="button"
      class="fg-transmission__close"
      aria-label="Hide theme music player for this session"
      title="Hide for this session"
    >
      <svg viewBox="0 0 12 12" width="10" height="10" focusable="false" aria-hidden="true">
        <line x1="2" y1="2" x2="10" y2="10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        <line x1="10" y1="2" x2="2" y2="10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
    </button>

    <button
      type="button"
      class="fg-transmission__button"
      aria-label="Play The Fuglys theme music"
      data-aria-idle="Play The Fuglys theme music"
      data-aria-playing="Pause The Fuglys theme music"
      data-aria-ended="Replay The Fuglys theme music"
    >
      <span class="fg-transmission__icon" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" focusable="false">
          <line x1="16" y1="8" x2="16" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M 11 14 Q 16 10 21 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="fg-arc fg-arc--inner" />
          <path d="M 8 12 Q 16 6 24 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-arc fg-arc--mid" />
          <path d="M 5 10 Q 16 2 27 10" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" class="fg-arc fg-arc--outer" />
          <rect x="12" y="25" width="8" height="2" fill="currentColor" />
          <line x1="6" y1="6" x2="26" y2="26" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-slash" />
        </svg>
      </span>

      <span class="fg-transmission__label">
        <span class="fg-label fg-label--idle-primary">TUNE IN?</span>
        <span class="fg-label fg-label--idle-hover">INCOMING TRANSMISSION</span>
        <span class="fg-label fg-label--playing">TRANSMITTING FROM THE PITS</span>
        <span class="fg-label fg-label--ended">SIGNAL LOST</span>
      </span>

      <span class="fg-transmission__rx" aria-hidden="true">RX</span>

      <span class="fg-transmission__replay">Retransmit?</span>
    </button>

    <span class="fg-transmission__waveform" aria-hidden="true">
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
    </span>

    <div
      class="fg-transmission__progress"
      role="slider"
      tabindex="0"
      aria-label="Theme music progress — click or use arrow keys to scrub"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
    >
      <div class="fg-transmission__progress-track">
        <div class="fg-transmission__progress-fill"></div>
      </div>
    </div>
  </div>
)}

{shouldRender && (
  <script>
    import { createThemeAudio, prefersReducedMotion } from '../lib/themeAudio.js';

    const root = document.getElementById('fg-transmission');
    if (root) {
      const button = root.querySelector('.fg-transmission__button');
      const closeBtn = root.querySelector('.fg-transmission__close');
      const progress = root.querySelector('.fg-transmission__progress');
      const progressFill = root.querySelector('.fg-transmission__progress-fill');
      const audioSrc = root.dataset.audioSrc;

      const SUPPRESSION = [
        /^\/cart(\/.*)?$/,
        /^\/checkout(\/.*)?$/,
        /^\/order(\/.*)?$/,
        /^\/media(\/.*)?$/,
      ];

      let progressInterval = null;

      function startProgressTracker() {
        stopProgressTracker();
        updateProgressDisplay();
        progressInterval = setInterval(updateProgressDisplay, 200);
      }

      function stopProgressTracker() {
        if (progressInterval) {
          clearInterval(progressInterval);
          progressInterval = null;
        }
      }

      function updateProgressDisplay() {
        const { percent } = controller.getProgress();
        progressFill.style.width = percent + '%';
        progress.setAttribute('aria-valuenow', String(Math.round(percent)));
      }

      const controller = createThemeAudio({
        namespace: 'fuglys',
        src: audioSrc,
        suppressionPaths: SUPPRESSION,
        onStateChange(state) {
          root.dataset.state = state;
          root.classList.remove('fg-state-idle', 'fg-state-playing', 'fg-state-replaying', 'fg-state-ended');
          root.classList.add('fg-state-' + state);
          if (state === 'idle') {
            button.setAttribute('aria-label', button.dataset.ariaIdle);
            stopProgressTracker();
            // refresh once to reflect persisted position
            updateProgressDisplay();
          } else if (state === 'playing' || state === 'replaying') {
            button.setAttribute('aria-label', button.dataset.ariaPlaying);
            startProgressTracker();
          } else if (state === 'ended') {
            button.setAttribute('aria-label', button.dataset.ariaEnded);
            stopProgressTracker();
            // ended = full bar
            progressFill.style.width = '100%';
            progress.setAttribute('aria-valuenow', '100');
          }
        },
        onDismiss() {
          root.dataset.dismissed = 'true';
          stopProgressTracker();
        },
      });

      // Initial dismiss check — hide if user dismissed earlier in this session
      if (controller.isDismissed()) {
        root.dataset.dismissed = 'true';
      }

      // Main play/pause click
      button.addEventListener('click', (e) => {
        e.preventDefault();
        controller.handleClick();
      });

      // Close (X) — dismiss for this session
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        controller.dismiss();
      });

      // Progress bar click-to-seek
      progress.addEventListener('click', (e) => {
        const rect = progress.getBoundingClientRect();
        const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        const { duration } = controller.getProgress();
        if (duration > 0) {
          const target = ratio * duration;
          controller.seekTo(target);
          updateProgressDisplay();
        } else {
          // Audio not yet loaded — seek will be queued via pendingSeek;
          // also kick off play so the user actually hears something.
          controller.handleClick();
          // Try the seek a beat later once Howl has metadata
          setTimeout(() => {
            const { duration: d2 } = controller.getProgress();
            if (d2 > 0) {
              controller.seekTo(ratio * d2);
              updateProgressDisplay();
            }
          }, 250);
        }
      });

      // Keyboard support on progress bar — arrow keys to scrub by 5 seconds,
      // Home jumps to 0, End jumps to duration.
      progress.addEventListener('keydown', (e) => {
        const { current, duration } = controller.getProgress();
        if (duration <= 0) return;
        let target = current;
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') target = Math.max(0, current - 5);
        else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') target = Math.min(duration, current + 5);
        else if (e.key === 'Home') target = 0;
        else if (e.key === 'End') target = duration;
        else return;
        e.preventDefault();
        controller.seekTo(target);
        updateProgressDisplay();
      });

      if (prefersReducedMotion()) {
        root.classList.add('fg-reduced-motion');
      }

      window.addEventListener('astro:page-load', () => {
        controller.applySuppression(window.location.pathname);
      });
      window.addEventListener('popstate', () => {
        controller.applySuppression(window.location.pathname);
      });
    }
  </script>
)}

<style>
  /* ─── Container — bottom-right both desktop and mobile ──────────────── */
  .fg-transmission {
    position: fixed;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 24px);
    right: calc(env(safe-area-inset-right, 0px) + 24px);
    top: auto;
    left: auto;
    z-index: 10000;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    gap: 6px;
    pointer-events: auto;
    min-width: 200px;
    max-width: 360px;
  }

  /* Hide entirely when dismissed */
  .fg-transmission[data-dismissed="true"] {
    display: none;
  }

  @media (max-width: 768px) {
    .fg-transmission {
      bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
      right: calc(env(safe-area-inset-right, 0px) + 16px);
      min-width: 0;
    }
    .fg-label--idle-hover,
    .fg-transmission__waveform,
    .fg-transmission__rx,
    .fg-transmission__replay {
      display: none !important;
    }
  }

  /* ─── Close (X) badge — top-right of widget ─────────────────────────── */
  .fg-transmission__close {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 22px;
    height: 22px;
    padding: 0;
    border: 1.5px solid var(--fg-text-primary, #FFFFFF);
    background: var(--fg-bg-footer, #1D3035);
    color: var(--fg-text-primary, #FFFFFF);
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    transition: background 150ms ease, transform 150ms ease;
  }
  .fg-transmission__close:hover {
    background: var(--fg-accent, #99132F);
    transform: scale(1.1);
  }
  .fg-transmission__close:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 2px;
  }

  /* ─── Main button — prominent crimson fill with always-visible label ─ */
  .fg-transmission__button {
    appearance: none;
    background: var(--fg-accent, #99132F);
    border: 1.5px solid var(--fg-accent, #99132F);
    color: var(--fg-text-primary, #FFFFFF);
    padding: 0.65rem 1rem;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-condensed, 'Barlow Condensed'), sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
  }

  .fg-transmission__button:hover {
    background: #b3162e;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
  }

  .fg-transmission__button:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 3px;
  }

  @media (max-width: 768px) {
    .fg-transmission__button {
      padding: 0.85rem 1rem;
    }
  }

  /* ─── Icon ─────────────────────────────────────────────────────────── */
  .fg-transmission__icon {
    display: inline-flex;
    color: var(--fg-text-primary, #FFFFFF);
  }

  .fg-arc {
    opacity: 0.85;
    animation-name: fg-flicker-arc;
    animation-timing-function: steps(1, end);
    animation-iteration-count: infinite;
  }
  .fg-arc--inner { animation-duration: 1.8s; }
  .fg-arc--mid   { animation-duration: 2.3s; animation-delay: 0.2s; }
  .fg-arc--outer { animation-duration: 2.6s; animation-delay: 0.4s; }

  @keyframes fg-flicker-arc {
    0%   { opacity: 0.95; }
    40%  { opacity: 0.6; }
    50%  { opacity: 0.95; }
    70%  { opacity: 0.45; }
    85%  { opacity: 0.8; }
    100% { opacity: 0.95; }
  }

  .fg-slash {
    opacity: 0;
    transition: opacity 250ms ease;
  }

  /* ─── Labels ───────────────────────────────────────────────────────── */
  .fg-transmission__label { display: inline-block; }
  .fg-label { display: none; }

  .fg-state-idle      .fg-label--idle-primary { display: inline; }
  .fg-state-playing   .fg-label--playing,
  .fg-state-replaying .fg-label--playing { display: inline; }
  .fg-state-ended     .fg-label--ended   { display: inline; }

  @media (hover: hover) {
    .fg-state-idle .fg-transmission__button:hover .fg-label--idle-primary,
    .fg-state-idle .fg-transmission__button:focus-visible .fg-label--idle-primary {
      display: none;
    }
    .fg-state-idle .fg-transmission__button:hover .fg-label--idle-hover,
    .fg-state-idle .fg-transmission__button:focus-visible .fg-label--idle-hover {
      display: inline;
    }
  }

  /* ─── Attention pulse on initial page load ─────────────────────────── */
  .fg-state-idle .fg-transmission__button {
    animation: fg-attention-pulse 1.5s ease-out 0.8s 2;
  }

  @keyframes fg-attention-pulse {
    0%   { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 0   rgba(153, 19, 47, 0.55); }
    70%  { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 14px rgba(153, 19, 47, 0); }
    100% { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 0   rgba(153, 19, 47, 0); }
  }

  /* ─── RX pulse — playing only ──────────────────────────────────────── */
  .fg-transmission__rx {
    display: none;
    color: var(--fg-text-primary, #FFFFFF);
    font-weight: 700;
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    animation: fg-rx-pulse 1s steps(2, end) infinite;
  }
  .fg-state-playing .fg-transmission__rx,
  .fg-state-replaying .fg-transmission__rx { display: inline; }

  @keyframes fg-rx-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }

  /* ─── Replay affordance — ended only ───────────────────────────────── */
  .fg-transmission__replay {
    display: none;
    color: var(--fg-text-primary, #FFFFFF);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.75rem;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .fg-state-ended .fg-transmission__replay { display: inline; }

  /* ─── Waveform — pulses during playing ─────────────────────────────── */
  .fg-transmission__waveform {
    display: none;
    align-items: flex-end;
    gap: 2px;
    height: 14px;
  }
  .fg-state-playing .fg-transmission__waveform,
  .fg-state-replaying .fg-transmission__waveform { display: inline-flex; }

  .fg-wave {
    display: inline-block;
    width: 2px;
    background: var(--fg-text-primary, #FFFFFF);
    animation: fg-wave 1s ease-in-out infinite;
    opacity: 0.95;
  }
  .fg-wave:nth-child(1) { animation-delay: 0s;    height: 6px; }
  .fg-wave:nth-child(2) { animation-delay: 0.15s; height: 10px; }
  .fg-wave:nth-child(3) { animation-delay: 0.3s;  height: 8px; }
  .fg-wave:nth-child(4) { animation-delay: 0.45s; height: 12px; }

  @keyframes fg-wave {
    0%, 100% { transform: scaleY(0.4); }
    50% { transform: scaleY(1); }
  }

  /* ─── Progress bar (v3.1) ──────────────────────────────────────────── */
  .fg-transmission__progress {
    height: 14px;
    padding: 5px 0; /* enlarges click target without enlarging visible bar */
    cursor: pointer;
    display: block;
    user-select: none;
  }
  .fg-transmission__progress:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .fg-transmission__progress-track {
    width: 100%;
    height: 4px;
    background: var(--fg-bg-footer, #1D3035);
    border: 1px solid rgba(153, 19, 47, 0.4);
    border-radius: 2px;
    overflow: hidden;
    transition: height 150ms ease;
  }
  .fg-transmission__progress:hover .fg-transmission__progress-track,
  .fg-transmission__progress:focus-visible .fg-transmission__progress-track {
    height: 6px;
  }
  .fg-transmission__progress-fill {
    height: 100%;
    width: 0%;
    background: var(--fg-accent, #99132F);
    transition: width 200ms linear;
  }
  /* Hide progress bar on idle (no track to scrub) — show on playing/ended */
  .fg-state-idle .fg-transmission__progress {
    display: none;
  }
  /* Mobile: show progress only when playing/ended (saves space) */
  @media (max-width: 768px) {
    .fg-transmission__progress {
      height: 10px;
      padding: 3px 0;
    }
  }

  /* ─── Playing/replaying state — keep crimson fill, slight darkening ─── */
  .fg-state-playing .fg-transmission__button,
  .fg-state-replaying .fg-transmission__button {
    background: #b3162e;
    border-color: #b3162e;
  }

  /* ─── Ended state — desaturated outline, slash through icon ─────────── */
  .fg-state-ended .fg-transmission__button {
    background: transparent;
    border-color: var(--fg-accent-faded, rgba(153, 19, 47, 0.4));
    color: var(--fg-accent-faded, rgba(153, 19, 47, 0.4));
  }
  .fg-state-ended .fg-transmission__icon { color: var(--fg-accent-faded, rgba(153, 19, 47, 0.4)); }
  .fg-state-ended .fg-slash { opacity: 1; }
  .fg-state-ended .fg-transmission__replay { color: var(--fg-text-primary, #FFFFFF); }

  /* ─── Reduced-motion variant ───────────────────────────────────────── */
  .fg-reduced-motion .fg-arc,
  .fg-reduced-motion .fg-transmission__rx,
  .fg-reduced-motion .fg-wave,
  .fg-reduced-motion .fg-state-idle .fg-transmission__button,
  .fg-reduced-motion .fg-transmission__progress-fill {
    animation: none !important;
    transition: none !important;
  }
  .fg-reduced-motion .fg-arc { opacity: 0.85; }
  .fg-reduced-motion .fg-transmission__rx { opacity: 1; }
  .fg-reduced-motion .fg-wave { transform: scaleY(0.6); }

  @media (prefers-reduced-motion: reduce) {
    .fg-arc,
    .fg-transmission__rx,
    .fg-wave,
    .fg-slash,
    .fg-state-idle .fg-transmission__button,
    .fg-transmission__progress-fill {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
