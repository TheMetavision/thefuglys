---
// src/components/FuglysTransmission.astro
//
// "Transmission Signal" — The Fuglys theme-tune control.
// Canonically: Harlan's scavenged radio rig broadcasting Wasteland Whispers.
//
// v3 INTERIM — 2026-04-29 — discoverability + cart-collision fix:
//   v1 was too discreet — the dim 60%-opacity outlined box on a dark teal
//   background was effectively invisible, and the hover-revealed label meant
//   visitors had no idea it was a theme tune until they happened to mouse over
//   it. Mobile users had no hover at all.
//
//   v3 changes (interim — Arc still owns the v3-final visual redesign):
//   - Position moved to BOTTOM-RIGHT on both desktop and mobile (was top-right
//     desktop). Cart icon owns the top-right corner uncontested. Audio control
//     gets its own zone at bottom-right, no collision possible.
//   - Idle state styled prominently: solid crimson fill (#99132F) with white
//     antenna icon, always-visible "TUNE IN?" label (in-canon per Arc D.1
//     optional sub-label), larger button (~52px tall).
//   - Attention pulse: subtle 3-second crimson pulse on initial page load to
//     catch the eye on first visit. Stops after 2 cycles. Respects
//     prefers-reduced-motion.
//   - Hover label "INCOMING TRANSMISSION" still appears on hover as a richer
//     secondary state for mouse-equipped users, no longer the primary
//     affordance.
//   - All Arc-spec copy strings preserved verbatim. Voice unchanged.
//
// v2 — 2026-04-29 — mobile visibility fix (kept):
//   Mobile icon bumped from 20px → 28px and button padding increased.
//
// v2.1 — 2026-04-29 — desktop cart collision fix (now obsolete — bottom-right
//   eliminates the cart conflict at root rather than stacking under it).
//
// Per Arc spec arc-spec-fuglys-theme-tune-content-2026-04-29.md:
//   - All copy strings verbatim (Section D)
//   - Palette: canonical Fuglys (Section A.3) — NO acid-green, NO rust-orange
//   - Voice anchor: scavenged radio rig coming alive (Section B.3)
//   - Irregular flicker (Section B.3 — Harlan's rig is not a metronome)
//   - Reduced-motion variant (Section D.6) — non-negotiable
//   - ARIA labels exact (Section D.5)
//
// Data is fetched in Layout.astro (via getThemeAudio) and passed as props.

interface Props {
  audioUrl: string | null;
  trackTitle?: string | null;
  trackArtist?: string | null;
}

const { audioUrl, trackTitle = 'The Fuglys Main Theme', trackArtist = '' } = Astro.props;

const shouldRender = !!audioUrl;
---

{shouldRender && (
  <div
    id="fg-transmission"
    class="fg-transmission fg-state-idle"
    data-state="idle"
    data-namespace="fuglys"
    data-audio-src={audioUrl}
    data-track-title={trackTitle}
    data-track-artist={trackArtist}
  >
    <button
      type="button"
      class="fg-transmission__button"
      aria-label="Play The Fuglys theme music"
      data-aria-idle="Play The Fuglys theme music"
      data-aria-playing="Pause The Fuglys theme music"
      data-aria-ended="Replay The Fuglys theme music"
    >
      <span class="fg-transmission__icon" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" focusable="false">
          <line x1="16" y1="8" x2="16" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M 11 14 Q 16 10 21 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="fg-arc fg-arc--inner" />
          <path d="M 8 12 Q 16 6 24 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-arc fg-arc--mid" />
          <path d="M 5 10 Q 16 2 27 10" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" class="fg-arc fg-arc--outer" />
          <rect x="12" y="25" width="8" height="2" fill="currentColor" />
          <line x1="6" y1="6" x2="26" y2="26" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-slash" />
        </svg>
      </span>

      <span class="fg-transmission__label">
        <span class="fg-label fg-label--idle-primary">TUNE IN?</span>
        <span class="fg-label fg-label--idle-hover">INCOMING TRANSMISSION</span>
        <span class="fg-label fg-label--playing">TRANSMITTING FROM THE PITS</span>
        <span class="fg-label fg-label--ended">SIGNAL LOST</span>
      </span>

      <span class="fg-transmission__rx" aria-hidden="true">RX</span>

      <span class="fg-transmission__replay">Retransmit?</span>
    </button>

    <span class="fg-transmission__waveform" aria-hidden="true">
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
    </span>
  </div>
)}

{shouldRender && (
  <script>
    import { createThemeAudio, prefersReducedMotion } from '../lib/themeAudio.js';

    const root = document.getElementById('fg-transmission');
    if (root) {
      const button = root.querySelector('.fg-transmission__button');
      const audioSrc = root.dataset.audioSrc;

      // Suppression paths — Fuglys-specific (Arc spec Section E.2)
      const SUPPRESSION = [
        /^\/cart(\/.*)?$/,
        /^\/checkout(\/.*)?$/,
        /^\/order(\/.*)?$/,
        /^\/media(\/.*)?$/,
      ];

      const controller = createThemeAudio({
        namespace: 'fuglys',
        src: audioSrc,
        suppressionPaths: SUPPRESSION,
        onStateChange(state) {
          root.dataset.state = state;
          root.classList.remove('fg-state-idle', 'fg-state-playing', 'fg-state-replaying', 'fg-state-ended');
          root.classList.add('fg-state-' + state);
          if (state === 'idle') {
            button.setAttribute('aria-label', button.dataset.ariaIdle);
          } else if (state === 'playing' || state === 'replaying') {
            button.setAttribute('aria-label', button.dataset.ariaPlaying);
          } else if (state === 'ended') {
            button.setAttribute('aria-label', button.dataset.ariaEnded);
          }
        },
      });

      button.addEventListener('click', (e) => {
        e.preventDefault();
        controller.handleClick();
      });

      if (prefersReducedMotion()) {
        root.classList.add('fg-reduced-motion');
      }

      window.addEventListener('astro:page-load', () => {
        controller.applySuppression(window.location.pathname);
      });
      window.addEventListener('popstate', () => {
        controller.applySuppression(window.location.pathname);
      });
    }
  </script>
)}

<style>
  /* ─── Container — bottom-right both desktop and mobile (v3) ─────────── */
  /* Cart owns the top-right corner uncontested. Theme tune gets its own
     zone at bottom-right, no collision possible. Same offset desktop and
     mobile = consistent mental model. */
  .fg-transmission {
    position: fixed;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 24px);
    right: calc(env(safe-area-inset-right, 0px) + 24px);
    top: auto;
    left: auto;
    z-index: 10000; /* above body::before noise overlay (z-index 9999) */
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    pointer-events: auto;
  }

  @media (max-width: 768px) {
    .fg-transmission {
      bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
      right: calc(env(safe-area-inset-right, 0px) + 16px);
    }
    /* mobile: simplified per brief Phase 2 — hide hover label, RX, waveform,
       replay text, but keep the primary "TUNE IN?" idle label visible. */
    .fg-label--idle-hover,
    .fg-transmission__waveform,
    .fg-transmission__rx,
    .fg-transmission__replay {
      display: none !important;
    }
  }

  /* ─── Button — prominent crimson fill with always-visible label ─────── */
  /* v3: solid crimson fill instead of dim outline. Visitor sees a clear
     branded affordance the moment they land — not a vague utility outline. */
  .fg-transmission__button {
    appearance: none;
    background: var(--fg-accent, #99132F);
    border: 1.5px solid var(--fg-accent, #99132F);
    color: var(--fg-text-primary, #FFFFFF);
    padding: 0.65rem 1rem;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-condensed, 'Barlow Condensed'), sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
  }

  .fg-transmission__button:hover {
    background: #b3162e; /* matches existing --color-primary-hover token */
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
  }

  .fg-transmission__button:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 3px;
  }

  /* Mobile: thumb-friendly tap target (~56px) */
  @media (max-width: 768px) {
    .fg-transmission__button {
      padding: 0.85rem 1rem;
    }
  }

  /* ─── Icon ─────────────────────────────────────────────────────────── */
  .fg-transmission__icon {
    display: inline-flex;
    color: var(--fg-text-primary, #FFFFFF);
  }

  /* arcs — irregular flicker on idle (Harlan's rig is not a metronome) */
  .fg-arc {
    opacity: 0.85;
    animation-name: fg-flicker-arc;
    animation-timing-function: steps(1, end);
    animation-iteration-count: infinite;
  }
  .fg-arc--inner { animation-duration: 1.8s; }
  .fg-arc--mid   { animation-duration: 2.3s; animation-delay: 0.2s; }
  .fg-arc--outer { animation-duration: 2.6s; animation-delay: 0.4s; }

  @keyframes fg-flicker-arc {
    0%   { opacity: 0.95; }
    40%  { opacity: 0.6; }
    50%  { opacity: 0.95; }
    70%  { opacity: 0.45; }
    85%  { opacity: 0.8; }
    100% { opacity: 0.95; }
  }

  /* slash hidden by default — shown only on ended state */
  .fg-slash {
    opacity: 0;
    transition: opacity 250ms ease;
  }

  /* ─── Labels — primary always-visible on idle, hover-revealed secondary ─ */
  .fg-transmission__label { display: inline-block; }
  .fg-label { display: none; }

  .fg-state-idle      .fg-label--idle-primary { display: inline; }
  .fg-state-playing   .fg-label--playing,
  .fg-state-replaying .fg-label--playing { display: inline; }
  .fg-state-ended     .fg-label--ended   { display: inline; }

  /* INCOMING TRANSMISSION fades in on hover/focus over the TUNE IN? primary */
  @media (hover: hover) {
    .fg-state-idle .fg-transmission__button:hover .fg-label--idle-primary,
    .fg-state-idle .fg-transmission__button:focus-visible .fg-label--idle-primary {
      display: none;
    }
    .fg-state-idle .fg-transmission__button:hover .fg-label--idle-hover,
    .fg-state-idle .fg-transmission__button:focus-visible .fg-label--idle-hover {
      display: inline;
    }
  }

  /* ─── Attention pulse on initial page load — 2 cycles, ~3s, then stops ─ */
  /* Subtle outer-glow pulse to catch the visitor's eye on first arrival.
     Doesn't loop forever — explicitly bounded to 2 iterations. */
  .fg-state-idle .fg-transmission__button {
    animation: fg-attention-pulse 1.5s ease-out 0.8s 2;
  }

  @keyframes fg-attention-pulse {
    0%   { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 0   rgba(153, 19, 47, 0.55); }
    70%  { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 14px rgba(153, 19, 47, 0); }
    100% { box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), 0 0 0 0   rgba(153, 19, 47, 0); }
  }

  /* ─── RX pulse — playing only (white on crimson now) ───────────────── */
  .fg-transmission__rx {
    display: none;
    color: var(--fg-text-primary, #FFFFFF);
    font-weight: 700;
    letter-spacing: 0.18em;
    font-size: 0.7rem;
    animation: fg-rx-pulse 1s steps(2, end) infinite;
  }
  .fg-state-playing .fg-transmission__rx,
  .fg-state-replaying .fg-transmission__rx { display: inline; }

  @keyframes fg-rx-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.45; }
  }

  /* ─── Replay affordance — ended only ───────────────────────────────── */
  .fg-transmission__replay {
    display: none;
    color: var(--fg-text-primary, #FFFFFF);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.75rem;
    text-transform: none;
    letter-spacing: 0.04em;
  }
  .fg-state-ended .fg-transmission__replay { display: inline; }

  /* ─── Waveform — pulses during playing (white on crimson) ───────────── */
  .fg-transmission__waveform {
    display: none;
    align-items: flex-end;
    gap: 2px;
    height: 14px;
  }
  .fg-state-playing .fg-transmission__waveform,
  .fg-state-replaying .fg-transmission__waveform { display: inline-flex; }

  .fg-wave {
    display: inline-b