---
// src/components/FuglysTransmission.astro
//
// "Transmission Signal" ‚Äî The Fuglys theme-tune control.
// Canonically: Harlan's scavenged radio rig broadcasting Wasteland Whispers.
//
// v3.1 ‚Äî 2026-04-30 ‚Äî adds dismiss + progress scrubber:
//   - Small circular X badge at the top-right corner of the widget. Click to
//     hide the player for the rest of this browser session. Returns next
//     visit (sessionStorage cleared on tab close).
//   - Progress bar below the main button shows playback position. Click
//     anywhere on the bar to seek to that position (works during playing,
//     and "back to beginning" by clicking the leftmost edge). ARIA slider
//     role + keyboard arrow-key support (5s steps).
//
// v3 INTERIM ‚Äî 2026-04-29 ‚Äî discoverability + cart-collision fix:
//   - Position bottom-right both desktop and mobile.
//   - Solid crimson fill, always-visible "TUNE IN?" label.
//   - Bounded attention pulse on initial load (2 cycles, ~3s, then stops).
//
// Per Arc spec arc-spec-fuglys-theme-tune-content-2026-04-29.md:
//   - All copy strings verbatim (Section D)
//   - Palette: canonical Fuglys (Section A.3)
//   - Voice anchor: scavenged radio rig coming alive (Section B.3)
//   - Reduced-motion variant (Section D.6) ‚Äî non-negotiable
//   - ARIA labels exact (Section D.5)
//
// Data is fetched in Layout.astro (via getThemeAudio) and passed as props.

interface Props {
  audioUrl: string | null;
  trackTitle?: string | null;
  trackArtist?: string | null;
}

const { audioUrl, trackTitle = 'The Fuglys Main Theme', trackArtist = '' } = Astro.props;

const shouldRender = !!audioUrl;
---

{shouldRender && (
  <div
    id="fg-transmission"
    class="fg-transmission fg-state-idle"
    data-state="idle"
    data-namespace="fuglys"
    data-audio-src={audioUrl}
    data-track-title={trackTitle}
    data-track-artist={trackArtist}
    data-dismissed="false"
  >
    <button
      type="button"
      class="fg-transmission__close"
      aria-label="Hide theme music player for this session"
      title="Hide for this session"
    >
      <svg viewBox="0 0 12 12" width="10" height="10" focusable="false" aria-hidden="true">
        <line x1="2" y1="2" x2="10" y2="10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
        <line x1="10" y1="2" x2="2" y2="10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
    </button>

    <button
      type="button"
      class="fg-transmission__button"
      aria-label="Play The Fuglys theme music"
      data-aria-idle="Play The Fuglys theme music"
      data-aria-playing="Pause The Fuglys theme music"
      data-aria-ended="Replay The Fuglys theme music"
    >
      <span class="fg-transmission__icon" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="22" height="22" focusable="false">
          <line x1="16" y1="8" x2="16" y2="26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <path d="M 11 14 Q 16 10 21 14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" class="fg-arc fg-arc--inner" />
          <path d="M 8 12 Q 16 6 24 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-arc fg-arc--mid" />
          <path d="M 5 10 Q 16 2 27 10" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" class="fg-arc fg-arc--outer" />
          <rect x="12" y="25" width="8" height="2" fill="currentColor" />
          <line x1="6" y1="6" x2="26" y2="26" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" class="fg-slash" />
        </svg>
      </span>

      <span class="fg-transmission__label">
        <span class="fg-label fg-label--idle-primary">TUNE IN?</span>
        <span class="fg-label fg-label--idle-hover">INCOMING TRANSMISSION</span>
        <span class="fg-label fg-label--playing">TRANSMITTING FROM THE PITS</span>
        <span class="fg-label fg-label--ended">SIGNAL LOST</span>
      </span>

      <span class="fg-transmission__rx" aria-hidden="true">RX</span>

      <span class="fg-transmission__replay">Retransmit?</span>
    </button>

    <span class="fg-transmission__waveform" aria-hidden="true">
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
      <span class="fg-wave"></span>
    </span>

    <div
      class="fg-transmission__progress"
      role="slider"
      tabindex="0"
      aria-label="Theme music progress ‚Äî click or use arrow keys to scrub"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
    >
      <div class="fg-transmission__progress-track">
        <div class="fg-transmission__progress-fill"></div>
      </div>
    </div>
  </div>
)}

{shouldRender && (
  <script>
    import { createThemeAudio, prefersReducedMotion } from '../lib/themeAudio.js';

    const root = document.getElementById('fg-transmission');
    if (root) {
      const button = root.querySelector('.fg-transmission__button');
      const closeBtn = root.querySelector('.fg-transmission__close');
      const progress = root.querySelector('.fg-transmission__progress');
      const progressFill = root.querySelector('.fg-transmission__progress-fill');
      const audioSrc = root.dataset.audioSrc;

      const SUPPRESSION = [
        /^\/cart(\/.*)?$/,
        /^\/checkout(\/.*)?$/,
        /^\/order(\/.*)?$/,
        /^\/media(\/.*)?$/,
      ];

      let progressInterval = null;

      function startProgressTracker() {
        stopProgressTracker();
        updateProgressDisplay();
        progressInterval = setInterval(updateProgressDisplay, 200);
      }

      function stopProgressTracker() {
        if (progressInterval) {
          clearInterval(progressInterval);
          progressInterval = null;
        }
      }

      function updateProgressDisplay() {
        const { percent } = controller.getProgress();
        progressFill.style.width = percent + '%';
        progress.setAttribute('aria-valuenow', String(Math.round(percent)));
      }

      const controller = createThemeAudio({
        namespace: 'fuglys',
        src: audioSrc,
        suppressionPaths: SUPPRESSION,
        onStateChange(state) {
          root.dataset.state = state;
          root.classList.remove('fg-state-idle', 'fg-state-playing', 'fg-state-replaying', 'fg-state-ended');
          root.classList.add('fg-state-' + state);
          if (state === 'idle') {
            button.setAttribute('aria-label', button.dataset.ariaIdle);
            stopProgressTracker();
            // refresh once to reflect persisted position
            updateProgressDisplay();
          } else if (state === 'playing' || state === 'replaying') {
            button.setAttribute('aria-label', button.dataset.ariaPlaying);
            startProgressTracker();
          } else if (state === 'ended') {
            button.setAttribute('aria-label', button.dataset.ariaEnded);
            stopProgressTracker();
            // ended = full bar
            progressFill.style.width = '100%';
            progress.setAttribute('aria-valuenow', '100');
          }
        },
        onDismiss() {
          root.dataset.dismissed = 'true';
          stopProgressTracker();
        },
      });

      // Initial dismiss check ‚Äî hide if user dismissed earlier in this session
      if (controller.isDismissed()) {
        root.dataset.dismissed = 'true';
      }

      // Main play/pause click
      button.addEventListener('click', (e) => {
        e.preventDefault();
        controller.handleClick();
      });

      // Close (X) ‚Äî dismiss for this session
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        controller.dismiss();
      });

      // Progress bar click-to-seek
      progress.addEventListener('click', (e) => {
        const rect = progress.getBoundingClientRect();
        const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        const { duration } = controller.getProgress();
        if (duration > 0) {
          const target = ratio * duration;
          controller.seekTo(target);
          updateProgressDisplay();
        } else {
          // Audio not yet loaded ‚Äî seek will be queued via pendingSeek;
          // also kick off play so the user actually hears something.
          controller.handleClick();
          // Try the seek a beat later once Howl has metadata
          setTimeout(() => {
            const { duration: d2 } = controller.getProgress();
            if (d2 > 0) {
              controller.seekTo(ratio * d2);
              updateProgressDisplay();
            }
          }, 250);
        }
      });

      // Keyboard support on progress bar ‚Äî arrow keys to scrub by 5 seconds,
      // Home jumps to 0, End jumps to duration.
      progress.addEventListener('keydown', (e) => {
        const { current, duration } = controller.getProgress();
        if (duration <= 0) return;
        let target = current;
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') target = Math.max(0, current - 5);
        else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') target = Math.min(duration, current + 5);
        else if (e.key === 'Home') target = 0;
        else if (e.key === 'End') target = duration;
        else return;
        e.preventDefault();
        controller.seekTo(target);
        updateProgressDisplay();
      });

      if (prefersReducedMotion()) {
        root.classList.add('fg-reduced-motion');
      }

      window.addEventListener('astro:page-load', () => {
        controller.applySuppression(window.location.pathname);
      });
      window.addEventListener('popstate', () => {
        controller.applySuppression(window.location.pathname);
      });
    }
  </script>
)}

<style>
  /* ‚îÄ‚îÄ‚îÄ Container ‚Äî bottom-right both desktop and mobile ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ */
  .fg-transmission {
    position: fixed;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 24px);
    right: calc(env(safe-area-inset-right, 0px) + 24px);
    top: auto;
    left: auto;
    z-index: 10000;
    display: inline-flex;
    flex-direction: column;
    align-items: stretch;
    gap: 6px;
    pointer-events: auto;
    min-width: 200px;
    max-width: 360px;
  }

  /* Hide entirely when dismissed */
  .fg-transmission[data-dismissed="true"] {
    display: none;
  }

  @media (max-width: 768px) {
    .fg-transmission {
      bottom: calc(env(safe-area-inset-bottom, 0px) + 16px);
      right: calc(env(safe-area-inset-right, 0px) + 16px);
      min-width: 0;
    }
    .fg-label--idle-hover,
    .fg-transmission__waveform,
    .fg-transmission__rx,
    .fg-transmission__replay {
      display: none !important;
    }
  }

  /* ‚îÄ‚îÄ‚îÄ Close (X) badge ‚Äî top-right of widget ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ */
  .fg-transmission__close {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 22px;
    height: 22px;
    padding: 0;
    border: 1.5px solid var(--fg-text-primary, #FFFFFF);
    background: var(--fg-bg-footer, #1D3035);
    color: var(--fg-text-primary, #FFFFFF);
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    transition: background 150ms ease, transform 150ms ease;
  }
  .fg-transmission__close:hover {
    background: var(--fg-accent, #99132F);
    transform: scale(1.1);
  }
  .fg-transmission__close:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 2px;
  }

  /* ‚îÄ‚îÄ‚îÄ Main button ‚Äî prominent crimson fill with always-visible label ‚îÄ */
  .fg-transmission__button {
    appearance: none;
    background: var(--fg-accent, #99132F);
    border: 1.5px solid var(--fg-accent, #99132F);
    color: var(--fg-text-primary, #FFFFFF);
    padding: 0.65rem 1rem;
    border-radius: 2px;
    cursor: pointer;
    font-family: var(--font-condensed, 'Barlow Condensed'), sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    transition: background 200ms ease, transform 200ms ease, box-shadow 200ms ease;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35);
  }

  .fg-transmission__button:hover {
    background: #b3162e;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.45);
  }

  .fg-transmission__button:focus-visible {
    outline: 2px solid var(--fg-text-primary, #FFFFFF);
    outline-offset: 3px;
  }

  @media (max-width: 768px) {
    .fg-transmission__button {
      padding: 0.85rem 1rem;
    }
  }

  /* ‚îÄ‚îÄ‚îÄ Icon ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚î