<section class="newsletter-section" id="newsletter">
  <div class="container">
    <div class="newsletter-inner">
      <p class="newsletter-eyebrow">Join the Crew</p>
      <h2 class="newsletter-headline">Wasteland Whispers</h2>
      <p class="newsletter-sub">Stay Weird. Stay Wild. Stay in the Loop.</p>

      <form
        class="newsletter-form"
        id="newsletter-form"
      >
        <div class="form-row">
          <input
            type="email"
            name="email"
            placeholder="Your email, survivor..."
            required
            class="newsletter-input"
            aria-label="Email address"
            id="newsletter-email"
          />
          <button type="submit" class="newsletter-btn">I'm In</button>
        </div>
      </form>

      <div class="newsletter-success" id="newsletter-success" style="display:none;">
        <div class="signal">
          <div class="signal__badge" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          </div>
          <div>
            <div class="signal__label">You're on the list</div>
            <div class="signal__headline">Welcome to the wasteland, weirdo.</div>
            <div class="signal__sub">Check your inbox. Or don't. We'll find you either way.</div>
          </div>
        </div>
      </div>

      <p class="newsletter-disclaimer">No spam. Just chaos, merch drops, and wasteland dispatches.</p>
    </div>
  </div>
</section>

<script>
