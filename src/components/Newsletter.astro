</script>

<style>
  .newsletter-section {
    background: #1e3238;
    padding: 80px 0;
    border-top: 1px solid rgba(153, 19, 47, 0.25);
    border-bottom: 1px solid rgba(153, 19, 47, 0.25);
  }

  .newsletter-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .newsletter-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #99132F;
    margin: 0 0 12px 0;
  }

  .newsletter-headline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 8px 0;
    line-height: 1.1;
    letter-spacing: 0.02em;
  }

  .newsletter-sub {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0 0 32px 0;
  }

  .newsletter-form {
    max-width: 480px;
    margin: 0 auto;
  }

  .form-row {
    display: flex;
    gap: 0;
  }

  .newsletter-input {
    flex: 1;
    padding: 14px 20px;
    background: #263F44;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-right: none;
    border-radius: 4px 0 0 4px;
    color: #fff;
    font-family: 'Barlow', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .newsletter-input:focus {
    border-color: #99132F;
  }

  .newsletter-btn {
    padding: 14px 28px;
    background: #99132F;
    color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none;
    border-radius: 0 4px 4px 0;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .newsletter-btn:hover {
    background: #b3162e;
  }

  .newsletter-disclaimer {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    margin: 16px 0 0 0;
  }

  /* Signal confirmation */
  .signal {
    display: flex;
    align-items: center;
    gap: 14px;
    background: #263F44;
    border: 1px solid rgba(255,255,255,0.08);
    border-left: 4px solid #99132F;
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    text-align: left;
    max-width: 480px;
    margin: 0 auto;
    animation: signalSlideIn 0.4s ease-out;
  }

  @keyframes signalSlideIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .signal__badge {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #99132F;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .signal__label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.625rem;
    color: #99132F;
    letter-spacing: 2.5px;
    margin-bottom: 3px;
    text-transform: uppercase;
    font-weight: 700;
  }

  .signal__headline {
    font-family: 'Barlow Condensed', sans-serif;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 900;
    line-height: 1.3;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .signal__sub {
    font-family: 'Barlow', sans-serif;
    color: rgba(255,255,255,0.45);
    font-size: 0.75rem;
    margin-top: 3px;
  }

  @media (max-width: 599px) {
    .form-row {
      flex-direction: column;
      gap: 8px;
    }

    .newsletter-input {
      border-right: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 4px;
      width: 100%;
      box-sizing: border-box;
    }

    .newsletter-btn {
      border-radius: 4px;
      width: 100%;
    }
  }
</style>
