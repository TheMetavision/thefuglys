        if (nlSuccess) nlSuccess.style.display = 'block';
      } else if (response.status === 422) {
        nlForm.style.display = 'none';
        if (nlSuccess) {
          nlSuccess.innerHTML = `
            <div class="signal">
              <div class="signal__badge" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div>
                <div class="signal__label">Already on the list</div>
