---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
import { getAllBlogPosts } from '../lib/sanity';

const posts = await getAllBlogPosts();

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}
---

<Layout title="Wasteland Whispers — The Fuglys" description="Wasteland Whispers: news, behind-the-scenes stories, character deep dives, and updates straight from The Fuglys universe.">
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-grid">
          <div class="page-hero-text">
            <div class="section-eyebrow">The Blog</div>
            <h1 class="page-title">Wasteland Whispers</h1>
            <div class="heading-rule"></div>
            <p class="page-intro">Dispatches from The Pits. News, lore, and behind-the-scenes chaos.</p>
          </div>
          <div class="page-hero-visual">
            <img
              src="/images/wasteland-whispers-hero.webp"
              alt="Two Fuglys characters chatting in a wasteland workshop"
              class="hero-whispers-img"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section posts-section">
      <div class="container">
        {posts.length === 0 ? (
          <div class="empty-state">
            <svg class="empty-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12.55a11 11 0 0 1 14.08 0"/>
              <path d="M1.42 9a16 16 0 0 1 21.16 0"/>
              <path d="M8.53 16.11a6 6 0 0 1 6.95 0"/>
              <circle cx="12" cy="20" r="1" fill="currentColor"/>
            </svg>
            <h2 class="empty-heading">No Dispatches Yet</h2>
            <p class="empty-body">The wasteland radio is quiet... for now. Check back soon, survivor.</p>
            <a href="/" class="btn btn-outline">Back to Home &rarr;</a>
          </div>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => (
              <a href={`/wasteland-whispers/${post.slug}`} class="post-card">
                <div class="post-image">
                  {post.featuredImage ? (
                    <img src={post.featuredImage} alt={post.title} class="post-img" loading="lazy" />
                  ) : (
                    <div class="post-img-placeholder"></div>
                  )}
                </div>
                <div class="post-content">
                  {post.publishedAt && (
                    <span class="post-date">{formatDate(post.publishedAt)}</span>
                  )}
                  <h2 class="post-title">{post.title}</h2>
                  {post.excerpt && (
                    <p class="post-excerpt">{post.excerpt}</p>
                  )}
                  {post.category && (
                    <span class="post-category">{post.category}</span>
                  )}
                  <span class="post-read-more">Read More &rarr;</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <Newsletter />
  </main>

  <Footer />
</Layout>

<style>

  .hero-whispers-img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
    object-fit: cover;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .posts-section {
    background: #263F44;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .post-card {
    background: #1e3238;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .post-card:hover {
    border-color: #99132F;
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }

  .post-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    width: 100%;
  }

  .post-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #263F44 0%, #1e3238 100%);
  }

  .post-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-date {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.35);
    display: block;
  }

  .post-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.3rem;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
    margin: 8px 0 12px;
  }

  .post-excerpt {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
    margin-bottom: 12px;
  }

  .post-category {
    display: inline-block;
    align-self: flex-start;
    background: rgba(153,19,47,0.15);
    color: #99132F;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid rgba(153,19,47,0.3);
    margin-bottom: 16px;
  }

  .post-read-more {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #99132F;
    display: inline-block;
    margin-top: auto;
    transition: color 0.2s, letter-spacing 0.2s;
  }

  .post-card:hover .post-read-more {
    color: #b3162e;
    letter-spacing: 0.16em;
  }

  /* Empty state */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 80px 0;
    gap: 16px;
  }

  .empty-icon {
    color: #99132F;
    margin-bottom: 8px;
  }

  .empty-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }

  .empty-body {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: rgba(255,255,255,0.45);
    margin: 0 0 8px;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
