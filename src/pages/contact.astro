---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Newsletter from '../components/Newsletter.astro';
---

<Layout title="Get In Touch — The Fuglys" description="Get in touch with The Fuglys team. General enquiries, licensing, press, and collaboration opportunities.">
  <Nav />

  <main>
    <section class="page-hero">
      <div class="container">
        <div class="page-hero-grid">
          <div class="page-hero-text">
            <div class="section-eyebrow">Contact</div>
            <h1 class="page-title">Get In Touch</h1>
            <div class="heading-rule"></div>
            <p class="page-intro">Got questions, ideas, or just want to talk wasteland? We want to hear from you.</p>
          </div>
          <div class="page-hero-visual">
            <img
              src="/images/contact-hero.webp"
              alt="Two Fuglys characters sitting in the dust at The Pits trailer park"
              class="hero-contact-img"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section contact-section">
      <div class="container">
        <div class="contact-layout">

          <div class="contact-form-col">
            <form
              class="contact-form"
              id="contact-form"
              name="contact"
              method="POST"
              data-netlify="true"
              novalidate
            >
              <input type="hidden" name="form-name" value="contact" />
              <div style="display:none">
                <input name="bot-field" />
              </div>

              <div class="form-group">
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="Your name" required />
              </div>

              <div class="form-group">
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" required />
              </div>

              <div class="form-group">
                <label for="subject" class="form-label">Subject</label>
                <input type="text" id="subject" name="subject" class="form-input" placeholder="What's this about?" required />
              </div>

              <div class="form-group">
                <label for="message" class="form-label">Message</label>
                <textarea id="message" name="message" class="form-input form-textarea" placeholder="Tell us what's on your mind..." required></textarea>
              </div>

              <button type="submit" class="btn btn-primary form-submit">Send Message</button>
            </form>

            <div class="form-success-msg" id="form-success" aria-live="polite">
              Message sent! We'll get back to you from the wasteland.
            </div>
          </div>

          <div class="contact-info-col">
            <div class="contact-info-panel">
              <h2 class="info-heading">Get in Touch</h2>

              <div class="info-block">
                <span class="info-label">Email</span>
                <a href="mailto:chaos@thefuglys.com" class="info-email">chaos@thefuglys.com</a>
              </div>

              <div class="info-block">
                <span class="info-label">Follow Us</span>
                <div class="info-socials">
                  <a href="https://www.youtube.com/@TheFuglys" target="_blank" rel="noopener noreferrer" class="info-social-link" aria-label="YouTube">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                    </svg>
                  </a>
                  <a href="https://www.instagram.com/the_fuglys" target="_blank" rel="noopener noreferrer" class="info-social-link" aria-label="Instagram">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                    </svg>
                  </a>
                  <a href="https://www.tiktok.com/@thefuglys" target="_blank" rel="noopener noreferrer" class="info-social-link" aria-label="TikTok">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
                    </svg>
                  </a>
                  <a href="https://x.com/TheFuglysMedia" target="_blank" rel="noopener noreferrer" class="info-social-link" aria-label="X (Twitter)">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  </a>
                  <a href="https://www.facebook.com/thefuglysmedia" target="_blank" rel="noopener noreferrer" class="info-social-link" aria-label="Facebook">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                </div>
              </div>

              <div class="info-press">
                <p>For press inquiries, brand collaborations, or licensing, please email directly.</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <div id="newsletter">
      <Newsletter />
    </div>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (form && successMsg) {
      form.style.display = 'none';
      successMsg.style.display = 'block';
    }
  });
</script>

<style>

  .hero-contact-img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    display: block;
    object-fit: cover;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }

  .contact-section {
    background: var(--color-bg, #263F44);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 64px;
    align-items: start;
  }

  /* Form column */
  .contact-form {
    display: flex;
    flex-direction: column;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 20px;
  }

  .form-label {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 8px;
  }

  .form-input {
    background: #263F44;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    padding: 14px 20px;
    color: #fff;
    font-family: 'Barlow', sans-serif;
    font-size: 0.95rem;
    width: 100%;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .form-input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .form-input:focus {
    border-color: #99132F;
    box-shadow: 0 0 0 2px rgba(153, 19, 47, 0.2);
  }

  .form-textarea {
    min-height: 160px;
    resize: vertical;
  }

  .form-submit {
    align-self: flex-start;
  }

  .form-success-msg {
    display: none;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #99132F;
    text-align: center;
    padding: 32px 0;
  }

  /* Info panel */
  .contact-info-panel {
    background: #1e3238;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 4px;
    padding: 36px;
  }

  .info-heading {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 24px;
  }

  .info-block {
    margin-bottom: 28px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4);
  }

  .info-email {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: #fff;
    text-decoration: none;
    transition: color 0.2s;
  }

  .info-email:hover {
    color: #99132F;
  }

  .info-socials {
    display: flex;
    flex-direction: row;
    gap: 16px;
    align-items: center;
  }

  .info-social-link {
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    transition: color 0.2s, transform 0.2s;
  }

  .info-social-link:hover {
    color: #fff;
    transform: scale(1.15);
  }

  .info-press {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 24px;
  }

  .info-press p {
    font-family: 'Barlow', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .form-submit {
      width: 100%;
    }
  }
</style>
